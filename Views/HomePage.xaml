<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.HomePage" 
             xmlns:models="clr-namespace:DoAnCSharp.Models"
             Title="Trang Chủ"
             BackgroundColor="#F4F7F9"
             NavigationPage.HasNavigationBar="False">

    <CollectionView x:Name="PoiCollectionView" SelectionMode="None">

        <CollectionView.Header>
            <VerticalStackLayout Spacing="20" Padding="20,40,20,10">

                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                        <Label Text="📍 Phố Ẩm Thực Vĩnh Khánh" FontSize="14" TextColor="#7F8C8D" FontAttributes="Bold" />
                        <Label x:Name="WelcomeLabel" Text="Khám phá món ngon!" FontSize="24" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,5,0,0" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 25" HeightRequest="50" WidthRequest="50" StrokeThickness="0">
                        <Image Source="dotnet_bot.png" Aspect="AspectFill" />
                    </Border>
                </Grid>

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="White" StrokeThickness="0" HeightRequest="55">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto, *" Padding="15,0">
                        <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" FontSize="20" />
                        <Label Grid.Column="1" Text="Tìm quán ốc, lẩu, nướng..." TextColor="#BDC3C7" VerticalOptions="Center" Margin="10,0,0,0" FontSize="15" />
                    </Grid>
                </Border>

                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="-20,0">
                    <HorizontalStackLayout Spacing="15" Padding="20,5,20,15">
                        <Border StrokeShape="RoundRectangle 20" BackgroundColor="#FF6B6B" StrokeThickness="0" Padding="20,12">
                            <Label Text="🔥 Phổ biến" TextColor="White" FontAttributes="Bold" FontSize="14" />
                        </Border>
                        <Border StrokeShape="RoundRectangle 20" BackgroundColor="White" StrokeThickness="0" Padding="20,12">
                            <Label Text="🐌 Quán Ốc" TextColor="#2C3E50" FontAttributes="Bold" FontSize="14" />
                        </Border>
                        <Border StrokeShape="RoundRectangle 20" BackgroundColor="White" StrokeThickness="0" Padding="20,12">
                            <Label Text="🍲 Lẩu &amp; Nướng" TextColor="#2C3E50" FontAttributes="Bold" FontSize="14" />
                        </Border>
                        <Border StrokeShape="RoundRectangle 20" BackgroundColor="White" StrokeThickness="0" Padding="20,12">
                            <Label Text="🥤 Giải khát" TextColor="#2C3E50" FontAttributes="Bold" FontSize="14" />
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>

                <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,5">
                    <Label x:Name="RecommendTitle" Grid.Column="0" Text="Đề xuất cho bạn" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="End" />
                    <Label Grid.Column="1" Text="Xem tất cả" TextColor="#FF6B6B" FontAttributes="Bold" VerticalOptions="End" />
                </Grid>

            </VerticalStackLayout>
        </CollectionView.Header>

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:AudioPOI">
                <Grid Padding="20,0,20,20">
                    <Border StrokeShape="RoundRectangle 20" BackgroundColor="White" StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,8" Radius="15" Opacity="0.08" />
                        </Border.Shadow>

                        <VerticalStackLayout>
                            <Grid HeightRequest="200">
                                <Image Source="{Binding ImageAsset}" Aspect="AspectFill" />

                                <BoxView Color="Black" Opacity="0.15" VerticalOptions="End" HeightRequest="80" />

                                <Border StrokeShape="RoundRectangle 20" BackgroundColor="#80000000" HorizontalOptions="End" VerticalOptions="Start" Margin="15" Padding="10" StrokeThickness="0">
                                    <Label Text="❤️" FontSize="16" />
                                </Border>

                                <Border StrokeShape="RoundRectangle 12" BackgroundColor="#FF6B6B" HorizontalOptions="Start" VerticalOptions="End" Margin="15" Padding="10,5" StrokeThickness="0">
                                    <Label Text="⭐ 4.8 Điểm" TextColor="White" FontSize="12" FontAttributes="Bold" />
                                </Border>
                            </Grid>

                            <VerticalStackLayout Padding="15,15,15,20" Spacing="8">
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" />

                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="📍" FontSize="14" />
                                    <Label Grid.Column="1" Text="Đường Vĩnh Khánh, Phường 8, Quận 4" FontSize="13" TextColor="#7F8C8D" VerticalOptions="Center" Margin="5,0,0,0" />
                                </Grid>

                                <Label Text="{Binding Description}" FontSize="14" TextColor="#95A5A6" MaxLines="2" LineBreakMode="TailTruncation" Margin="0,5,0,0" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.Footer>
            <BoxView HeightRequest="30" Color="Transparent" />
        </CollectionView.Footer>

    </CollectionView>
</ContentPage>