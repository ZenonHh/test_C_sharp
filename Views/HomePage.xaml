<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.HomePage" 
             xmlns:models="clr-namespace:DoAnCSharp.Models"
             Title="Trang Chủ"
             BackgroundColor="#F4F7F9"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="0,40,0,30">

            <Grid ColumnDefinitions="*, Auto" Padding="20,0">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="📍 Phố Ẩm Thực Vĩnh Khánh" FontSize="14" TextColor="#7F8C8D" FontAttributes="Bold" />
                    <Label x:Name="WelcomeLabel" Text="{Binding Lang.T[welcome]}" FontSize="24" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,5,0,0" />
                </VerticalStackLayout>
            </Grid>

            <Border Margin="20,0" StrokeShape="RoundRectangle 15" BackgroundColor="White" StrokeThickness="0" HeightRequest="55">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto, *" Padding="15,0">
                    <Label Grid.Column="0" Text="🔍" VerticalOptions="Center" FontSize="20" />
                    <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="Tìm quán ốc, lẩu, nướng..." 
                           TextColor="#2C3E50" VerticalOptions="Center" Margin="10,0,0,0" FontSize="15"
                           TextChanged="OnSearchTextChanged" BackgroundColor="Transparent" ClearButtonVisibility="WhileEditing"/>
                </Grid>
            </Border>

            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="15" Padding="20,5,20,15">
                    <Button x:Name="BtnPhoBien" Text="🔥 Phổ biến" Clicked="OnCategoryClicked" BackgroundColor="#FF6B6B" TextColor="White" CornerRadius="20" FontAttributes="Bold" HeightRequest="45" Padding="20,0"/>
                    <Button x:Name="BtnQuanOc" Text="🐌 Quán Ốc" Clicked="OnCategoryClicked" BackgroundColor="White" TextColor="#2C3E50" CornerRadius="20" FontAttributes="Bold" HeightRequest="45" Padding="20,0"/>
                    <Button x:Name="BtnLauNuong" Text="🍲 Lẩu &amp; Nướng" Clicked="OnCategoryClicked" BackgroundColor="White" TextColor="#2C3E50" CornerRadius="20" FontAttributes="Bold" HeightRequest="45" Padding="20,0"/>
                </HorizontalStackLayout>
            </ScrollView>

            <VerticalStackLayout IsVisible="{Binding IsRecommendedVisible}">
                <Grid ColumnDefinitions="*, Auto" Margin="20,10,20,5">
                    <Label Grid.Column="0" Text="{Binding Lang.T[recommend]}" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="End" />
                </Grid>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecommendedPois}" Spacing="15" Padding="20,10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:AudioPOI">
                            <Border BackgroundColor="White" StrokeThickness="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPoiTapped"/>
                                </Border.GestureRecognizers>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                                </Border.Shadow>
                                <Grid ColumnDefinitions="100, *" Padding="10">
                                    <Image Grid.Column="0" Source="{Binding ImageAsset}" Aspect="AspectFill" HeightRequest="90">
                                        <Image.Clip>
                                            <RoundRectangleGeometry CornerRadius="10" Rect="0,0,100,90"/>
                                        </Image.Clip>
                                    </Image>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="#7F8C8D" MaxLines="2" LineBreakMode="TailTruncation" Margin="0,5,0,0"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Label Text="{Binding SearchResultTitle}" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" Margin="20,10,20,5" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding AllPois}" Spacing="15" Padding="20,10">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:AudioPOI">
                        <Border BackgroundColor="White" StrokeThickness="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiTapped"/>
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="100, *" Padding="10">
                                <Image Grid.Column="0" Source="{Binding ImageAsset}" Aspect="AspectFill" HeightRequest="90">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="10" Rect="0,0,100,90"/>
                                    </Image.Clip>
                                </Image>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="#7F8C8D" MaxLines="2" LineBreakMode="TailTruncation" Margin="0,5,0,0"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>