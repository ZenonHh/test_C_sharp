<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:map="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="DoAnCSharp.Views.MapPage"
             Title="Bản đồ Vĩnh Khánh">

    <Grid>
        <map:MapView x:Name="foodMapView" 
                     VerticalOptions="Fill" 
                     HorizontalOptions="Fill" 
                     IsZoomButtonVisible="False"
                     IsMyLocationButtonVisible="False"
                     IsNorthingButtonVisible="False"
                     ZIndex="0"/>

        <Border VerticalOptions="Start" HorizontalOptions="Fill" Margin="15, 40, 15, 0"
                BackgroundColor="White" StrokeThickness="0" HeightRequest="50" ZIndex="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *, Auto" Padding="15,0">
                <Label Grid.Column="0" Text="🔍" FontSize="20" VerticalOptions="Center" TextColor="#7F8C8D" />
                <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="Tìm quán ăn, món ốc..." 
                       TextColor="#2C3E50" PlaceholderColor="#95A5A6" BackgroundColor="Transparent" 
                       VerticalOptions="Center" Margin="10,0" ClearButtonVisibility="WhileEditing" />

                <Border Grid.Column="2" StrokeThickness="0" HeightRequest="30" WidthRequest="30" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Image Source="dotnet_bot.png" Aspect="AspectFill" />
                </Border>
            </Grid>
        </Border>

        <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="End" Margin="0, 110, 15, 0" Spacing="12" ZIndex="1">
            <Button Text="🎯" FontSize="16" Clicked="CustomMyLocationClicked"
                    BackgroundColor="White" CornerRadius="19" WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>
            <Button Text="🌐" FontSize="16" Clicked="OnLanguageClicked"
                    BackgroundColor="White" CornerRadius="19" WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <Border x:Name="PoiDetailCard" IsVisible="False" VerticalOptions="End" HorizontalOptions="Fill"
                Margin="20, 0, 20, 30" Padding="0" BackgroundColor="White" StrokeThickness="0" ZIndex="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.15" />
            </Border.Shadow>
            <Grid RowDefinitions="150, Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                <Image x:Name="DetailImage" Grid.Row="0" Grid.ColumnSpan="2" Aspect="AspectFill" HeightRequest="150" />
                <Button Grid.Row="0" Grid.Column="1" Text="✕" BackgroundColor="#80000000" TextColor="White" 
                        FontSize="14" Clicked="CloseDetailClicked" WidthRequest="32" HeightRequest="32" 
                        CornerRadius="16" Margin="10" VerticalOptions="Start" HorizontalOptions="End" Padding="0" />
                <Label x:Name="DetailName" Grid.Row="1" Grid.Column="0" Text="Tên Quán" FontAttributes="Bold" 
                       FontSize="22" TextColor="#2C3E50" Margin="20, 15, 20, 5" />
                <Label x:Name="DetailDescription" Grid.Row="2" Grid.ColumnSpan="2" Text="Mô tả chi tiết..." 
                       TextColor="#7F8C8D" FontSize="14" Margin="20, 0, 20, 15" LineBreakMode="WordWrap" />
                <Button x:Name="PlayReviewButton" Grid.Row="3" Grid.ColumnSpan="2" Text="🔊 Nghe Review" 
                        BackgroundColor="#FF4757" TextColor="White" CornerRadius="15" FontAttributes="Bold" 
                        Clicked="PlayReviewFromDetailClicked" HeightRequest="45" Margin="20, 0, 20, 20" />
            </Grid>
        </Border>

        <Border x:Name="AudioPlayerUI" IsVisible="False" VerticalOptions="End" HorizontalOptions="Fill"
                Margin="20, 0, 20, 20" Padding="15, 12" BackgroundColor="#EB1A1A1A" StrokeThickness="0" ZIndex="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                <Grid Grid.Column="0" WidthRequest="32" HeightRequest="32">
                    <Label Text="🔊" FontSize="28" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <ActivityIndicator x:Name="TranslationLoader" IsRunning="False" IsVisible="False" Color="White" Scale="0.8"/>
                </Grid>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                    <Label x:Name="AudioStatusLabel" Text="Đang phát review:" TextColor="Gray" FontSize="11"/>
                    <Label x:Name="AudioText" Text="Ốc Oanh" TextColor="White" FontAttributes="Bold" FontSize="17" MaxLines="1" LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
                <Button x:Name="PlayStopButton" Grid.Column="2" Text="⏹" Clicked="ToggleAudioClicked" 
                        BackgroundColor="#FF4444" TextColor="White" CornerRadius="22" WidthRequest="44" HeightRequest="44" Padding="0" VerticalOptions="Center"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>