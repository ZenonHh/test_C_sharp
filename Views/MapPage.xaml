<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:map="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="DoAnCSharp.Views.MapPage"
             Title="Bản đồ Vĩnh Khánh">

    <Grid>
        <map:MapView x:Name="foodMapView" ZIndex="0" VerticalOptions="Fill" HorizontalOptions="Fill" 
                      IsZoomButtonVisible="False" IsMyLocationButtonVisible="False" IsNorthingButtonVisible="False"/>

        <Border VerticalOptions="Start" HorizontalOptions="Fill" Margin="15, 40, 15, 0" BackgroundColor="White" StrokeThickness="0" HeightRequest="50" ZIndex="2">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="15,0">
                <Label Grid.Column="0" Text="🔍" FontSize="20" VerticalOptions="Center" TextColor="#7F8C8D" />
                <Entry x:Name="SearchEntry" Grid.Column="1" Placeholder="Tìm quán ăn, món ốc..." TextChanged="OnSearchTextChanged" TextColor="#2C3E50" PlaceholderColor="#95A5A6" BackgroundColor="Transparent" VerticalOptions="Center" Margin="10,0" ClearButtonVisibility="WhileEditing" />
                <Border Grid.Column="2" StrokeThickness="0" HeightRequest="30" WidthRequest="30" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Image Source="dotnet_bot.png" Aspect="AspectFill" />
                </Border>
            </Grid>
        </Border>

        <Border x:Name="SearchSuggestionsContainer" IsVisible="False" VerticalOptions="Start" HorizontalOptions="Fill" Margin="15, 95, 15, 0" BackgroundColor="White" StrokeThickness="0" ZIndex="3" MaximumHeightRequest="200">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
            </Border.Shadow>
            <CollectionView x:Name="SuggestionsList" SelectionMode="Single" SelectionChanged="OnSuggestionSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="15, 12">
                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" VerticalOptions="Center" />
                            <BoxView HeightRequest="1" Color="#F4F6F8" VerticalOptions="End" HorizontalOptions="Fill" Margin="-15,0,-15,-12"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="End" Margin="0, 110, 15, 0" Spacing="12" ZIndex="1">
            <Button Text="📷" Clicked="OnScanQRClicked" BackgroundColor="White" CornerRadius="19" WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>

            <Button Text="🎯" FontSize="16" Clicked="CustomMyLocationClicked" BackgroundColor="White" CornerRadius="19" WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>

            <Button Text="🌐" FontSize="16" Clicked="OnLanguageClicked" BackgroundColor="White" CornerRadius="19" WidthRequest="38" HeightRequest="38" Padding="0">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Opacity="0.2" />
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <Border x:Name="PoiDetailCard" IsVisible="False" VerticalOptions="End" HorizontalOptions="Fill" Margin="20, 0, 20, 30" Padding="0" BackgroundColor="White" StrokeThickness="0" ZIndex="4">
            <Border.GestureRecognizers>
                <TapGestureRecognizer />
            </Border.GestureRecognizers>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#2C3E50" Offset="0,10" Radius="25" Opacity="0.15" />
            </Border.Shadow>

            <Grid RowDefinitions="180, Auto, Auto, Auto" ColumnDefinitions="*, Auto">
                <Image x:Name="DetailImage" Grid.Row="0" Grid.ColumnSpan="2" Aspect="AspectFill" HeightRequest="180" />
                <BoxView Grid.Row="0" Grid.ColumnSpan="2" Color="Black" Opacity="0.2" VerticalOptions="Start" HeightRequest="60" />

                <Button Grid.Row="0" Grid.Column="1" Text="✕" BackgroundColor="#B3000000" TextColor="White" FontSize="14" FontAttributes="Bold" Clicked="CloseDetailClicked" WidthRequest="34" HeightRequest="34" CornerRadius="17" Margin="15" VerticalOptions="Start" HorizontalOptions="End" Padding="0" />

                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="20, 15, 20, 5" Spacing="8">
                    <Label x:Name="DetailName" Text="Tên Quán" FontAttributes="Bold" FontSize="24" TextColor="#2C3E50" />

                    <HorizontalStackLayout Spacing="10">
                        <Border BackgroundColor="#FFF0F0" StrokeThickness="0" Padding="8,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Text="⭐ 4.8" FontSize="13" TextColor="#FF6B6B" FontAttributes="Bold" />
                        </Border>

                        <Border BackgroundColor="#E8F6F3" StrokeThickness="0" Padding="8,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label x:Name="DetailDistance" Text="📍 Đang tính toán..." FontSize="13" TextColor="#16A085" FontAttributes="Bold" />
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Label x:Name="DetailDescription" Grid.Row="2" Grid.ColumnSpan="2" Text="Mô tả chi tiết..." TextColor="#7F8C8D" FontSize="14" Margin="20, 10, 20, 15" LineBreakMode="WordWrap" />

                <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="20, 0, 20, 20">
                    <Button Grid.Column="0"
                            Text="📍 Chỉ đường"
                            BackgroundColor="#3498DB"
                            TextColor="White"
                            CornerRadius="18"
                            FontAttributes="Bold"
                            FontSize="15"
                            Clicked="OnGetDirectionsClicked"
                            HeightRequest="50">
                        <Button.Shadow>
                            <Shadow Brush="#3498DB" Offset="0,4" Radius="10" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>

                    <Button x:Name="PlayReviewButton"
                            Grid.Column="1"
                            Text="🔊 Nghe Review"
                            BackgroundColor="#FF6B6B"
                            TextColor="White"
                            CornerRadius="18"
                            FontAttributes="Bold"
                            FontSize="15"
                            Clicked="PlayReviewFromDetailClicked"
                            HeightRequest="50">
                        <Button.Shadow>
                            <Shadow Brush="#FF6B6B" Offset="0,4" Radius="10" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="AudioPlayerUI" IsVisible="False" VerticalOptions="End" HorizontalOptions="Fill" Margin="20, 0, 20, 20" Padding="15, 12" BackgroundColor="#EB1A1A1A" StrokeThickness="0" ZIndex="5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                <Grid Grid.Column="0" WidthRequest="32" HeightRequest="32">
                    <Label Text="🔊" FontSize="28" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <ActivityIndicator x:Name="TranslationLoader" IsRunning="False" IsVisible="False" Color="White" Scale="0.8"/>
                </Grid>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                    <Label x:Name="AudioStatusLabel" Text="Đang phát review:" TextColor="Gray" FontSize="11"/>
                    <Label x:Name="AudioText" Text="Ốc Oanh" TextColor="White" FontAttributes="Bold" FontSize="17" MaxLines="1" LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
                <Button x:Name="PlayStopButton" Grid.Column="2" Text="⏹" Clicked="ToggleAudioClicked" BackgroundColor="#FF4444" TextColor="White" CornerRadius="22" WidthRequest="44" HeightRequest="44" Padding="0" VerticalOptions="Center"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>