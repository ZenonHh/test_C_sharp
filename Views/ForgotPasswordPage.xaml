<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.ForgotPasswordPage"
             Title="Khôi phục mật khẩu"
             BackgroundColor="#F4F6F8">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" Margin="10,20,10,0">

            <Label Text="Quên Mật Khẩu? 🔒" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50" />
            
            <Label Text="Vui lòng nhập Email đã đăng ký để nhận mã xác nhận." FontSize="14" TextColor="#7F8C8D" HorizontalTextAlignment="Center" Margin="0,0,0,10" />
            
            <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                <Entry x:Name="EmailEntry" Placeholder="Nhập Email của bạn..." Keyboard="Email" BackgroundColor="Transparent"/>
            </Border>
            
            <Button x:Name="SendCodeButton" Text="Gửi mã xác nhận" Clicked="OnSendCodeClicked" BackgroundColor="#3F8CFF" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold"/>

            <VerticalStackLayout x:Name="Step2Container" Spacing="20" IsVisible="False" Margin="0,20,0,0">
                <Label Text="Đã gửi mã OTP! Vui lòng kiểm tra." TextColor="#27AE60" FontAttributes="Bold" HorizontalOptions="Center"/>
                
                <Label x:Name="TimerLabel" Text="Mã hết hạn trong: 15s" TextColor="#E74C3C" FontAttributes="Bold" HorizontalOptions="Center" FontSize="16"/>

                <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                    <Entry x:Name="OtpEntry" Placeholder="Nhập mã OTP 4 số..." Keyboard="Numeric" BackgroundColor="Transparent"/>
                </Border>

                <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                    <Entry x:Name="NewPasswordEntry" Placeholder="Nhập Mật khẩu mới..." IsPassword="True" BackgroundColor="Transparent"/>
                </Border>

                <Button x:Name="ConfirmButton" Text="Xác nhận Đổi Mật Khẩu" Clicked="OnResetPasswordClicked" BackgroundColor="#FF4757" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold"/>
                
                <Button x:Name="ResendCodeButton" Text="Gửi lại mã OTP" Clicked="OnSendCodeClicked" BackgroundColor="#7F8C8D" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" IsVisible="False"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>