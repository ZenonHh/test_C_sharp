<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.RegisterPage"
             xmlns:viewmodels="clr-namespace:DoAnCSharp.ViewModels"
             x:DataType="viewmodels:RegisterViewModel"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="30,50,30,30" Spacing="0">

            <Grid HeightRequest="50" HorizontalOptions="Start" Margin="0,0,0,20">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                </Grid.GestureRecognizers>
                <Label Text="❮" FontSize="20" FontAttributes="Bold" TextColor="#333" VerticalOptions="Center"/>
            </Grid>

            <Label Text="Tạo Tài Khoản" FontSize="32" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,0,0,10"/>
            <Label Text="Tạo tài khoản mới để trải nghiệm FoodTour" FontSize="15" TextColor="#7F8C8D" Margin="0,0,0,35"/>

            <Grid HeightRequest="130" WidthRequest="130" HorizontalOptions="Center" Margin="0,0,0,30">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAvatarClicked"/>
                </Grid.GestureRecognizers>

                <Border StrokeShape="RoundRectangle 65" StrokeThickness="3" Stroke="#FF6B6B" HeightRequest="130" WidthRequest="130" BackgroundColor="#FDF0F0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.1"/>
                    </Border.Shadow>
                    <Image Source="{Binding AvatarSource}" Aspect="AspectFill" />
                </Border>

                <Border StrokeShape="RoundRectangle 20" StrokeThickness="2" Stroke="White" HeightRequest="40" WidthRequest="40" BackgroundColor="#FF6B6B" VerticalOptions="End" HorizontalOptions="End" Margin="0,0,-5,-5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvatarClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="📷" FontSize="20" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="18" Margin="0,0,0,30">

                <Label Text="Tên đăng nhập" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="5,0,0,0"/>
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E0E0E0" BackgroundColor="#F9FAFB" HeightRequest="55">
                    <Entry Text="{Binding FullName}" Placeholder="Nhập họ và tên" TextColor="#2C3E50" Margin="15,0"/>
                </Border>

                <Label Text="Email" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="5,0,0,0"/>
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E0E0E0" BackgroundColor="#F9FAFB" HeightRequest="55">
                    <Entry Text="{Binding Email}" Placeholder="Nhập địa chỉ email" TextColor="#2C3E50" Keyboard="Email" Margin="15,0"/>
                </Border>

                <Label Text="Mật khẩu" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="5,0,0,0"/>
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E0E0E0" BackgroundColor="#F9FAFB" HeightRequest="55">
                    <Entry Text="{Binding Password}" Placeholder="Tạo mật khẩu" TextColor="#2C3E50" IsPassword="True" Margin="15,0"/>
                </Border>

                <Label Text="Xác nhận mật khẩu" FontSize="14" FontAttributes="Bold" TextColor="#34495E" Margin="5,0,0,0"/>
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E0E0E0" BackgroundColor="#F9FAFB" HeightRequest="55">
                    <Entry Text="{Binding ConfirmPassword}" Placeholder="Nhập lại mật khẩu" TextColor="#2C3E50" IsPassword="True" Margin="15,0"/>
                </Border>

                <Label Text="{Binding Error}" TextColor="#FF4757" FontSize="13" FontAttributes="Italic" HorizontalOptions="Center" Margin="0,5,0,0" />
            </VerticalStackLayout>

            <Button Text="ĐĂNG KÝ" Command="{Binding RegisterCommand}" BackgroundColor="#FF6B6B" TextColor="White" CornerRadius="12" HeightRequest="55" FontAttributes="Bold" FontSize="16" Margin="0,0,0,20">
                <Button.Shadow>
                    <Shadow Brush="#FF6B6B" Offset="0,6" Radius="10" Opacity="0.3"/>
                </Button.Shadow>
            </Button>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,10,0,0">
                <Label Text="Đã có tài khoản?" TextColor="#7F8C8D" FontSize="14"/>
                <Label Text="Đăng nhập" TextColor="#FF6B6B" FontSize="14" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>