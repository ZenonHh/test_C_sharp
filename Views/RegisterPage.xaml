<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.RegisterPage"
             xmlns:viewmodels="clr-namespace:DoAnCSharp.ViewModels"
             x:DataType="viewmodels:RegisterViewModel"
             BackgroundColor="#F4F6F8"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
            
            <Image Source="dotnet_bot.png" HeightRequest="100" HorizontalOptions="Center" Margin="0,0,0,20"/>
            
            <Label Text="Tạo Tài Khoản" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
            <Label Text="Trải nghiệm food tour Vĩnh Khánh" FontSize="14" HorizontalOptions="Center" TextColor="#7F8C8D" Margin="0,-15,0,20"/>

            <Frame BorderColor="Transparent" CornerRadius="12" HasShadow="True" Padding="0" HeightRequest="55" BackgroundColor="White">
                <Entry Placeholder="Tên đầy đủ của bạn" Text="{Binding FullName}" TextColor="#2C3E50" Margin="15,0"/>
            </Frame>

            <Frame BorderColor="Transparent" CornerRadius="12" HasShadow="True" Padding="0" HeightRequest="55" BackgroundColor="White">
                <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" TextColor="#2C3E50" Margin="15,0"/>
            </Frame>

            <Frame BorderColor="Transparent" CornerRadius="12" HasShadow="True" Padding="0" HeightRequest="55" BackgroundColor="White">
                <Entry Placeholder="Mật khẩu" Text="{Binding Password}" IsPassword="True" TextColor="#2C3E50" Margin="15,0"/>
            </Frame>

            <Button Text="ĐĂNG KÝ NGAY" Command="{Binding RegisterCommand}" BackgroundColor="#FF4757" TextColor="White" HeightRequest="55" CornerRadius="12" FontAttributes="Bold" Margin="0,15,0,0"/>

            <Button Text="Đã có tài khoản? Đăng nhập" Command="{Binding GoToLoginCommand}" BackgroundColor="Transparent" TextColor="#3F8CFF" FontAttributes="Bold" Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>