<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoAnCSharp.Views.ProfilePage"
             xmlns:viewmodels="clr-namespace:DoAnCSharp.ViewModels"
             xmlns:models="clr-namespace:DoAnCSharp.Models"
             xmlns:converters="clr-namespace:DoAnCSharp.Converters"
             x:DataType="viewmodels:ProfileViewModel"
             BackgroundColor="#F4F6F8"
             Title="{Binding Lang[profile]}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20,40,20,20">

             <!-- ✅ PHẦN CHƯA ĐĂNG NHẬP -->
            <VerticalStackLayout x:Name="LoginContainer" Spacing="20" IsVisible="{Binding IsLoggedIn, Converter={StaticResource InvertedBoolConverter}}">
                <Label Text="👋 Chào mừng bạn!" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
                <Label Text="Vui lòng đăng nhập hoặc đăng ký để tiếp tục" FontSize="14" HorizontalOptions="Center" TextColor="#7F8C8D"/>

                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="White" Padding="15">
                    <Entry x:Name="EmailEntry" Placeholder="Email" TextColor="#2C3E50" PlaceholderColor="#95A5A6" BackgroundColor="Transparent" Margin="0,10,0,0"/>
                </Border>
                <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="White" Padding="15">
                    <Entry x:Name="PasswordEntry" Placeholder="Mật khẩu" IsPassword="True" TextColor="#2C3E50" PlaceholderColor="#95A5A6" BackgroundColor="Transparent"/>
                </Border>

                <Button Text="🔐 Đăng Nhập" Command="{Binding LoginCommand}" CommandParameter="{Binding Source={x:Reference LoginContainer}}" BackgroundColor="#3F8CFF" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold"/>
                <Button Text="📝 Đăng Ký" Command="{Binding RegisterCommand}" CommandParameter="{Binding Source={x:Reference LoginContainer}}" BackgroundColor="#27AE60" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold"/>
            </VerticalStackLayout>

             <!-- ✅ PHẦN ĐÃ ĐĂNG NHẬP -->
            <VerticalStackLayout x:Name="ProfileContainer" Spacing="20" IsVisible="{Binding IsLoggedIn}">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                    <Border StrokeShape="RoundRectangle 60" HeightRequest="120" WidthRequest="120" StrokeThickness="3" Stroke="#3F8CFF" HorizontalOptions="Center">
                        <Image Source="{Binding CurrentUser.Avatar}" Aspect="AspectFill" />
                    </Border>
                    <Label Text="{Binding CurrentUser.FullName}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
                    <Label Text="{Binding CurrentUser.Email}" FontSize="14" TextColor="#7F8C8D" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05" />
                    </Border.Shadow>

                    <VerticalStackLayout>

                        <!-- 🎧 Lịch sử đã nghe -->
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnHistoryTapped" />
                            </Grid.GestureRecognizers>
                            <Label Text="🎧" FontSize="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Lịch sử đã nghe" FontSize="16" VerticalOptions="Center" Margin="15,0,0,0" TextColor="#34495E"/>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F4F6F8" Margin="20,0"/>

                        <!-- 💳 Thanh toán -->
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPaymentTapped" />
                            </Grid.GestureRecognizers>
                            <Label Text="💳" FontSize="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Thanh toán" FontSize="16" VerticalOptions="Center" Margin="15,0,0,0" TextColor="#34495E"/>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F4F6F8" Margin="20,0"/>

                        <!-- 🌐 Chọn ngôn ngữ -->
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangeLanguageCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Text="🌐" FontSize="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding Lang[language_choice]}" FontSize="16" VerticalOptions="Center" Margin="15,0,0,0" TextColor="#34495E"/>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F4F6F8" Margin="20,0"/>

                        <!-- 👤 Chỉnh sửa thông tin -->
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="20">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EditProfileCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Text="👤" FontSize="22" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Chỉnh sửa thông tin" FontSize="16" VerticalOptions="Center" Margin="15,0,0,0" TextColor="#34495E"/>
                            <Label Grid.Column="2" Text="❯" FontSize="16" TextColor="#BDC3C7" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <Button Text="{Binding Lang[logout]}" Command="{Binding LogoutCommand}" BackgroundColor="#FF4757" TextColor="White" CornerRadius="12" HeightRequest="55" FontAttributes="Bold" FontSize="16" Margin="0,10,0,0"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
